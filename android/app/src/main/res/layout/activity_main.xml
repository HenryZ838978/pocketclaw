<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center_horizontal"
    android:background="#0D0D0D">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🦀"
        android:textSize="72sp"
        android:layout_marginTop="48dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CrabAgent"
        android:textSize="32sp"
        android:textColor="#FF6B35"
        android:textStyle="bold"
        android:layout_marginTop="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your pocket butler"
        android:textSize="16sp"
        android:textColor="#888888"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Checking status..."
        android:textSize="14sp"
        android:textColor="#CCCCCC"
        android:padding="16dp"
        android:background="#1A1A1A"
        android:layout_marginTop="48dp"
        android:fontFamily="monospace" />

    <TextView
        android:id="@+id/cloud_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="☁️ Cloud Brain: checking..."
        android:textSize="14sp"
        android:textColor="#CCCCCC"
        android:padding="16dp"
        android:background="#1A1A1A"
        android:layout_marginTop="8dp"
        android:fontFamily="monospace" />

    <Button
        android:id="@+id/btn_notification_permission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Grant Notification Access"
        android:layout_marginTop="32dp"
        android:backgroundTint="#FF6B35"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btn_start_service"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Start Butler Service"
        android:layout_marginTop="12dp"
        android:backgroundTint="#333333"
        android:textColor="#FF6B35" />

</LinearLayout>
